# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# See CLEAN_CODE_IMPLEMENTATION.md for detailed explanations

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/skills_trend_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true

# CORS Origins (comma-separated) - Allow frontend to access API
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================================================
# LLM CONFIGURATION (Groq)
# Get your FREE API key from: https://console.groq.com/keys
# ============================================================================
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MIN_INTERVAL=2.0
GROQ_MAX_TOKENS=800
GROQ_TEMPERATURE=0.1
GROQ_TOP_P=0.9

# ============================================================================
# PROCESSING CONFIGURATION
# Mode: batch (recommended), stable, ultra, normal
# ============================================================================
PROCESS_MODE=batch
LLM_BATCH_SIZE=8
LLM_MAX_WORKERS=2
LLM_MAX_RETRIES=3
LLM_BASE_RETRY_DELAY=30

# ============================================================================
# SCRAPER CONFIGURATION
# ============================================================================
SCRAPER_MIN_DELAY=2.0
SCRAPER_MAX_DELAY=5.0
SCRAPER_DEFAULT_LOCATION=Indonesia
SCRAPER_CONNECTION_TIMEOUT=10
SCRAPER_READ_TIMEOUT=10

# ============================================================================
# SKILL NORMALIZATION
# ============================================================================
SKILL_NORMALIZATION_SIMILARITY_THRESHOLD=0.85
SKILL_CHAR_LIMIT_PER_JOB=1200

# ============================================================================
# BATCH PROCESSING
# ============================================================================
BATCH_SIZE_DB_COMMIT=20
BATCH_SIZE_LLM_REQUEST=8

# ============================================================================
# LOGGING
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_hashed_password_here

# ============================================================================
# FRONTEND CONFIGURATION
# File: frontend/.env
# ============================================================================
VITE_API_URL=http://localhost:8001/api
